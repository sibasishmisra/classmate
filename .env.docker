# Docker Environment Configuration
# Copy this file to .env when using Docker Compose
# Usage: cp .env.docker .env

# ============================================
# Required Configuration
# ============================================

# Claude API Key (REQUIRED)
# Get your key from: https://console.anthropic.com/
CLAUDE_API_KEY=your_claude_api_key_here

# ============================================
# Optional Configuration (with defaults)
# ============================================

# Application name
NEXT_PUBLIC_APP_NAME=ClassMate.info

# Topic input limits
NEXT_PUBLIC_MAX_TOPIC_LENGTH=500
NEXT_PUBLIC_MAX_HISTORY_ENTRIES=10

# Rate limiting
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_MS=60000

# ============================================
# Docker Deployment Instructions
# ============================================
# 1. Copy this file: cp .env.docker .env
# 2. Edit .env and add your Claude API key
# 3. Build and run: docker-compose up -d
# 4. Visit: http://localhost:3000
# 5. Check health: http://localhost:3000/api/health
# ============================================
