# ============================================
# ClassMate.info Environment Configuration
# ============================================
# This file documents all required environment variables for the application.
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local to version control - it contains sensitive data.

# ============================================
# Claude API Configuration (REQUIRED)
# ============================================
# The Claude API key is required for AI-powered educational explanations.
# This key must be kept secret and never exposed to the client browser.
# All Claude API calls are made from server-side API routes only.
#
# How to get your Claude API key:
# 1. Visit https://console.anthropic.com/
# 2. Sign up or log in to your Anthropic account
# 3. Navigate to API Keys section
# 4. Create a new API key or copy an existing one
# 5. Paste the key below (format: sk-ant-...)
#
# Security notes:
# - Store this key ONLY in .env.local (never in .env.example)
# - The key is accessed server-side via process.env.CLAUDE_API_KEY
# - Never expose this key in client-side code or commit it to git
# - Rotate the key immediately if it's ever exposed
#
CLAUDE_API_KEY=your_claude_api_key_here

# ============================================
# Application Configuration (OPTIONAL)
# ============================================
# These variables configure application behavior and limits.
# Default values are provided and can be customized as needed.

# Application name displayed in the UI
NEXT_PUBLIC_APP_NAME=ClassMate.info

# Maximum length for topic input (characters)
# Validates: Requirement 2.2 - Topic input validation
NEXT_PUBLIC_MAX_TOPIC_LENGTH=500

# Maximum number of topics stored in session history
# Validates: Requirement 11.2 - Session history size limit
NEXT_PUBLIC_MAX_HISTORY_ENTRIES=10

# ============================================
# Rate Limiting Configuration (OPTIONAL)
# ============================================
# Protects the API from abuse by limiting requests per IP address.
# Validates: Requirement 14.4 - Rate limiting on API routes

# Maximum number of API requests allowed per time window
RATE_LIMIT_REQUESTS=10

# Time window for rate limiting in milliseconds (60000ms = 1 minute)
RATE_LIMIT_WINDOW_MS=60000

# ============================================
# Setup Instructions:
# ============================================
# 1. Copy this file to .env.local:
#    cp .env.example .env.local
#
# 2. Get your Claude API key from https://console.anthropic.com/
#
# 3. Edit .env.local and replace 'your_claude_api_key_here' with your actual API key
#
# 4. Verify your setup:
#    npm run dev
#    Visit http://localhost:3000/api/health to check API key configuration
#
# 5. IMPORTANT: Never commit .env.local to version control
#    (It's already in .gitignore)
#
# ============================================
# Troubleshooting:
# ============================================
# If you see "CLAUDE_API_KEY not configured" errors:
# - Ensure .env.local exists in the project root
# - Verify the API key is correctly copied (starts with sk-ant-)
# - Restart the development server after changing environment variables
# - Check that .env.local is not in .gitignore (it should be)
#
# For more information, see SETUP.md
# ============================================
